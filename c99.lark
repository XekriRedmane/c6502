// C99 lexer grammar (Lark).
// Translates the hand-written grammar files:
//   docs/ints_grammar.txt, docs/floats_grammar.txt,
//   docs/chars_grammar.txt, docs/strings_grammar.txt
//
// Keyword classification is done in the wrapper (lexer.py): the KEYWORDS set
// is applied to IDENTIFIER tokens after tokenization.

// -- Integer constant (docs/ints_grammar.txt) --
_INT_L: /[lL]/
_INT_LL: /ll|LL/
_INT_U: /[uU]/
_INT_SUFFIX: _INT_U (_INT_LL | _INT_L)? | (_INT_LL | _INT_L) _INT_U?
_HEX_INT: /0[xX][0-9a-fA-F]+/
_DECIMAL_INT: /[1-9][0-9]*/
_OCTAL_INT: /0[0-7]*/
INTEGER_CONSTANT: (_HEX_INT | _DECIMAL_INT | _OCTAL_INT) _INT_SUFFIX?

// -- Floating constant (docs/floats_grammar.txt) --
// NOTE: fractions use an explicit (?:...) group. Without it, the top-level `|`
// leaks out when these are concatenated into the enclosing terminal.
_FLOAT_SUFFIX: /[flFL]/
_DEC_EXP: /[eE][+-]?[0-9]+/
_BIN_EXP: /[pP][+-]?[0-9]+/
_DEC_FRAC: /(?:[0-9]*\.[0-9]+|[0-9]+\.)/
_HEX_FRAC: /(?:[0-9a-fA-F]*\.[0-9a-fA-F]+|[0-9a-fA-F]+\.?)/
_DEC_FLOAT: _DEC_FRAC _DEC_EXP? | /[0-9]+/ _DEC_EXP
_HEX_FLOAT: /0[xX]/ _HEX_FRAC _BIN_EXP
FLOATING_CONSTANT: (_HEX_FLOAT | _DEC_FLOAT) _FLOAT_SUFFIX?

// -- Escape sequences (docs/chars_grammar.txt) --
_SIMPLE_ESC: /\\['"?\\abfnrtv]/
_OCT_ESC: /\\[0-7]{1,3}/
_HEX_ESC: /\\x[0-9a-fA-F]+/
_U_ESC: /\\u[0-9a-fA-F]{4}/
_BIG_U_ESC: /\\U[0-9a-fA-F]{8}/
_ESCAPE: _SIMPLE_ESC | _OCT_ESC | _HEX_ESC | _U_ESC | _BIG_U_ESC

// -- Character constant (docs/chars_grammar.txt) --
// Printable ASCII minus ' (0x27) and \ (0x5C). Using \] (instead of \x5D)
// because Lark translates \x5D to a bare ], which would close the class early.
_C_CHAR: /[\x20-\x26\x28-\x5B\]-\x7E]/ | _ESCAPE
CHARACTER_CONSTANT: /L?'/ _C_CHAR+ /'/

// -- String literal (docs/strings_grammar.txt) --
// Printable ASCII minus " (0x22) and \ (0x5C). Same \] trick as _C_CHAR.
_S_CHAR: /[\x20\x21\x23-\x5B\]-\x7E]/ | _ESCAPE
STRING_LITERAL: /L?"/ _S_CHAR* /"/

// -- Error-catching terminals for malformed numerics.
// Each matches a pattern that our strict grammar rejects but that a naive
// tokenizer would otherwise split into pieces (e.g. "0x" + "g"). The wrapper
// (lexer.py) raises LexError when it sees an INVALID_NUMBER.
// NOTE: *+ (possessive) prevents the regex from backtracking into a shorter
// match when the lookahead later fails — otherwise e.g. "0x.FFp0" would
// produce a spurious "0x.F" BAD match by shrinking the second digit run.
_BAD_HEX_PREFIX: /0[xX](?![0-9a-fA-F\.])/
_BAD_HEX_DOT: /0[xX]\.(?![0-9a-fA-F])/
_BAD_HEX_NO_EXP: /0[xX][0-9a-fA-F]*+\.[0-9a-fA-F]*+(?![pP])/
_BAD_HEX_EXP: /0[xX][0-9a-fA-F]*+\.?[0-9a-fA-F]*+[pP](?![+-]?[0-9])/
_BAD_DEC_EXP: /(?:[0-9]+|[0-9]*\.[0-9]+|[0-9]+\.)[eE](?![+-]?[0-9])/
INVALID_NUMBER: _BAD_HEX_PREFIX | _BAD_HEX_DOT | _BAD_HEX_NO_EXP | _BAD_HEX_EXP | _BAD_DEC_EXP

// -- Keywords (C99 §6.4.1). One terminal per keyword so parser rules can
//    refer to IF / WHILE / etc. directly. String terminals get higher
//    priority than IDENTIFIER on equal-length matches, so `int` wins over
//    IDENTIFIER for input `int` while `intx` falls through to IDENTIFIER
//    via longest match.
//    Naming: uppercase the keyword; strip leading `_` (so `_Bool` → `BOOL`).
//    Keep this list in sync with KEYWORDS in lexer.py.
AUTO: "auto"
BREAK: "break"
CASE: "case"
CHAR: "char"
CONST: "const"
CONTINUE: "continue"
DEFAULT: "default"
DO: "do"
DOUBLE: "double"
ELSE: "else"
ENUM: "enum"
EXTERN: "extern"
FLOAT: "float"
FOR: "for"
GOTO: "goto"
IF: "if"
INLINE: "inline"
INT: "int"
LONG: "long"
REGISTER: "register"
RESTRICT: "restrict"
RETURN: "return"
SHORT: "short"
SIGNED: "signed"
SIZEOF: "sizeof"
STATIC: "static"
STRUCT: "struct"
SWITCH: "switch"
TYPEDEF: "typedef"
UNION: "union"
UNSIGNED: "unsigned"
VOID: "void"
VOLATILE: "volatile"
WHILE: "while"
BOOL: "_Bool"
COMPLEX: "_Complex"
IMAGINARY: "_Imaginary"

// -- Identifier (placeholder alphabet, pending a grammar) --
IDENTIFIER: /[a-zA-Z_][a-zA-Z_0-9]*/

// -- Symbols (C99 punctuators). One terminal per symbol so parser rules
//    can refer to them by name (e.g. LPAREN, ARROW, PLUS_ASSIGN).
//    Keep this list in sync with SYMBOLS in lexer.py.
ELLIPSIS: "..."
LSHIFT_ASSIGN: "<<="
RSHIFT_ASSIGN: ">>="
ARROW: "->"
PLUSPLUS: "++"
MINUSMINUS: "--"
LSHIFT: "<<"
RSHIFT: ">>"
LE: "<="
GE: ">="
EQ: "=="
NE: "!="
ANDAND: "&&"
OROR: "||"
STAR_ASSIGN: "*="
SLASH_ASSIGN: "/="
PERCENT_ASSIGN: "%="
PLUS_ASSIGN: "+="
MINUS_ASSIGN: "-="
AMP_ASSIGN: "&="
CARET_ASSIGN: "^="
PIPE_ASSIGN: "|="
HASHHASH: "##"
LBRACKET: "["
RBRACKET: "]"
LPAREN: "("
RPAREN: ")"
LBRACE: "{"
RBRACE: "}"
DOT: "."
AMP: "&"
STAR: "*"
PLUS: "+"
MINUS: "-"
TILDE: "~"
BANG: "!"
SLASH: "/"
PERCENT: "%"
LT: "<"
GT: ">"
CARET: "^"
PIPE: "|"
QUESTION: "?"
COLON: ":"
SEMICOLON: ";"
ASSIGN: "="
COMMA: ","
HASH: "#"

// -- Whitespace (ignored) --
WS: /[ \t\n\f]+/
%ignore WS

// Top-level: a translation unit is a list of function declarations.
start: declaration*

declaration: function_decl | var_decl
specifier: type_specifier | STATIC | EXTERN
var_decl: specifier+ IDENTIFIER (ASSIGN exp)? SEMICOLON
function_decl: specifier+ IDENTIFIER LPAREN param_list RPAREN (SEMICOLON | block)

// `(void)` is the empty-parameter idiom; otherwise a comma-separated
// list of `int IDENTIFIER`. Parameter names aren't kept on
// function_definitions today (the AST's Function only carries name
// and body), but they are kept on function_decl for the future
// type-checking pass.
param_list: VOID | type_specifier+ IDENTIFIER (COMMA type_specifier+ IDENTIFIER)*
type_specifier: INT | LONG

block: LBRACE block_item* RBRACE
block_item: statement    -> stmt_item
          | declaration  -> decl_item
// for-init permits a variable declaration or an expression-or-empty,
// per C99 §6.8.5: function declarations aren't legal here.
for_init: var_decl | exp? SEMICOLON

// `if (exp) statement (else statement)?` — the optional else is the
// classic dangling-else ambiguity. Lark's LALR(1) backend resolves
// shift-reduce conflicts in favor of shifting, which binds `else` to
// the nearest preceding unmatched `if` (the C99-correct rule). Lark
// emits a warning for the conflict; the warning is the expected
// behavior, not a bug.
// Labeled statements (`label: stmt`) and `goto label;` per C99 §6.8.1
// and §6.8.6. Labels live in their own namespace and are scoped to the
// enclosing function — both rules are enforced by the
// label_resolution pass, not the grammar.
//
// The labeled-statement rule introduces a shift-reduce conflict at
// statement-start: after seeing `IDENTIFIER`, lookahead `COLON` could
// either start a labeled_stmt (shift) or finish reducing the
// IDENTIFIER to a primary expression (reduce, via the
// expression_stmt path). Lark's LALR(1) backend prefers shift, which
// picks the labeled_stmt branch — exactly what we want. Inside an
// expression (e.g. ternary) the parser state is different (kernel
// items don't include the labeled_stmt option), so `a ? b : c`
// continues to parse as a ternary even though `b` is also an
// IDENTIFIER followed by COLON.
statement: RETURN exp SEMICOLON                                     -> return_stmt
         | exp SEMICOLON                                            -> expression_stmt
         | IF LPAREN exp RPAREN statement (ELSE statement)?         -> if_stmt
         | GOTO IDENTIFIER SEMICOLON                                -> goto_stmt
         | IDENTIFIER COLON statement                               -> labeled_stmt
         | block                                                    -> compound_stmt
         | BREAK SEMICOLON                                          -> break_stmt
         | CONTINUE SEMICOLON                                       -> continue_stmt
         | WHILE LPAREN exp RPAREN statement                        -> while_stmt
         | DO statement WHILE LPAREN exp RPAREN SEMICOLON           -> do_stmt
         | FOR LPAREN for_init exp? SEMICOLON exp? RPAREN statement -> for_stmt
         | SEMICOLON                                                -> null_stmt

// Expression precedence (low to high) via the standard precedence-
// climbing layout: each level recurses left into itself (for left
// associativity) and right into the next-tighter level. Lark's `?`
// rule prefix inlines a level when it has a single child, so the
// AST sees no extra wrapping for "passes through to next level".

?exp: assignment_exp

// Right-recursive so `=` is right-associative: `a = b = c` parses as
// `a = (b = c)`. The LHS is `conditional_exp` (one level tighter than
// assignment, same as C99's §6.5.16 but looser than C99's `unary_exp`),
// which means the grammar accepts things like `1+2=3+4` and
// `(1?2:a)=5` — semantic analysis will reject the first by checking
// for modifiable lvalues. The compound-assignment alternatives share
// the `compound_assign` builder, which dispatches on the operator
// token's type and emits the desugared `lval = lval OP rval`.

?assignment_exp: conditional_exp ASSIGN assignment_exp         -> assignment
               | conditional_exp PLUS_ASSIGN assignment_exp    -> compound_assign
               | conditional_exp MINUS_ASSIGN assignment_exp   -> compound_assign
               | conditional_exp STAR_ASSIGN assignment_exp    -> compound_assign
               | conditional_exp SLASH_ASSIGN assignment_exp   -> compound_assign
               | conditional_exp PERCENT_ASSIGN assignment_exp -> compound_assign
               | conditional_exp AMP_ASSIGN assignment_exp     -> compound_assign
               | conditional_exp PIPE_ASSIGN assignment_exp    -> compound_assign
               | conditional_exp CARET_ASSIGN assignment_exp   -> compound_assign
               | conditional_exp LSHIFT_ASSIGN assignment_exp  -> compound_assign
               | conditional_exp RSHIFT_ASSIGN assignment_exp  -> compound_assign
               | conditional_exp
// Ternary `cond ? then : else`. The condition is `logical_or_exp`, so
// `||` binds tighter than `?:`. The true-clause is a full `exp` (so
// `x ? x = 1 : 2` parses as `x ? (x = 1) : 2`). The false-clause is
// `conditional_exp`, which gives `?:` right-associativity (`a ? 1 : b ?
// 2 : 3` parses as `a ? 1 : (b ? 2 : 3)`) and keeps assignments out of
// the false-clause slot — so `1 ? 2 : a = 5` parses as `(1 ? 2 : a) = 5`
// via the outer assignment rule, not `1 ? 2 : (a = 5)`.
?conditional_exp: logical_or_exp QUESTION exp COLON conditional_exp -> conditional
                | logical_or_exp
?logical_or_exp: logical_or_exp OROR logical_and_exp  -> logical_or
               | logical_and_exp
?logical_and_exp: logical_and_exp ANDAND or_exp       -> logical_and
                | or_exp
?or_exp: or_exp PIPE xor_exp        -> bitwise_or
       | xor_exp
?xor_exp: xor_exp CARET and_exp     -> bitwise_xor
        | and_exp
?and_exp: and_exp AMP equality_exp  -> bitwise_and
        | equality_exp
?equality_exp: equality_exp EQ relational_exp  -> equal
             | equality_exp NE relational_exp  -> not_equal
             | relational_exp
?relational_exp: relational_exp LT shift_exp   -> less_than
               | relational_exp GT shift_exp   -> greater_than
               | relational_exp LE shift_exp   -> less_or_equal
               | relational_exp GE shift_exp   -> greater_or_equal
               | shift_exp
?shift_exp: shift_exp LSHIFT add_exp -> left_shift
          | shift_exp RSHIFT add_exp -> right_shift
          | add_exp
?add_exp: add_exp PLUS mul_exp      -> add
        | add_exp MINUS mul_exp     -> subtract
        | mul_exp
?mul_exp: mul_exp STAR cast_exp     -> multiply
        | mul_exp SLASH cast_exp    -> divide
        | mul_exp PERCENT cast_exp  -> modulo
        | cast_exp
// Cast expression (C99 §6.5.4) sits between unary and multiplicative.
// Right-recursive so `(int)(long)x` parses as `(int)((long)x)`. The
// LPAREN-vs-paren-expr ambiguity is resolved at LALR(1) by the next
// token after `(`: type_specifier (INT/LONG) → cast; anything else
// → parenthesised exp.
?cast_exp: LPAREN type_name RPAREN cast_exp  -> cast
         | unary_exp
// type-name (§6.7.6) — for now just one or more type_specifiers (no
// abstract declarators since we have no pointer/array types). The
// transformer reuses `_resolve_data_type` to map the run of INT/LONG
// tokens to `Int()` or `Long()`.
type_name: type_specifier+
// Prefix `++`/`--` sit at unary precedence (alongside `-`/`~`/`!`) and
// desugar at parse time to `lval = lval ± 1` — same shape as a compound
// assignment, so no AST node is needed. Postfix `a++`/`a--` need their
// own node because they evaluate to the *old* value of the operand
// while still mutating it; that can't be expressed by reusing
// Assignment/Binary alone. The unary-operator alternative takes a
// `cast_exp` (per §6.5.3.1) so `-(int)x` parses as `-((int)x)`;
// prefix ++/-- keep their unary_exp operand because the cast result
// isn't an lvalue.
?unary_exp: unop cast_exp            -> unary
          | PLUSPLUS unary_exp       -> pre_increment
          | MINUSMINUS unary_exp     -> pre_decrement
          | postfix_exp
?postfix_exp: postfix_exp PLUSPLUS   -> post_increment
            | postfix_exp MINUSMINUS -> post_decrement
            | atom
// Function call sits at atom level (one form of primary expression
// per C99 §6.5.2). The IDENTIFIER LPAREN form is shift/reduce-
// distinguishable from the bare-identifier form on LPAREN lookahead:
// after IDENTIFIER, LALR(1) sees LPAREN and shifts (function_call);
// any other lookahead reduces to identifier→atom. The AST node
// FunctionCall(name, args) takes the callee as a string identifier
// (not a general expression), so the LHS is restricted to
// IDENTIFIER directly — no `(p)(args)` form yet.
?atom: const                       -> constant
     | LPAREN exp RPAREN                      -> paren
     | IDENTIFIER LPAREN arg_list? RPAREN     -> function_call
     | IDENTIFIER                             -> identifier
const: INTEGER_CONSTANT

unop: MINUS                         -> negate
    | TILDE                         -> complement
    | BANG                          -> logical_not

// Argument-list nodes: each arg is a full `exp` (assignment-level
// expression — comma operator isn't supported, so this matches C's
// argument-expression-list grammar).
arg_list: exp (COMMA exp)*

// Lexer-only start rule. Lark's LALR mode drops terminals that aren't
// reachable from a start rule, which would shrink the lexer as long as
// the parser rules above don't cover everything. Passing this as an
// additional start in lexer.py keeps every terminal alive for .lex().
// Remove when the real parser rules cover the full language.
lex_only: (AUTO | BREAK | CASE | CHAR | CONST | CONTINUE
         | DEFAULT | DO | DOUBLE | ELSE | ENUM | EXTERN
         | FLOAT | FOR | GOTO | IF | INLINE | INT | LONG
         | REGISTER | RESTRICT | RETURN | SHORT | SIGNED
         | SIZEOF | STATIC | STRUCT | SWITCH | TYPEDEF | UNION
         | UNSIGNED | VOID | VOLATILE | WHILE
         | BOOL | COMPLEX | IMAGINARY
         | INTEGER_CONSTANT | FLOATING_CONSTANT | CHARACTER_CONSTANT
         | STRING_LITERAL | IDENTIFIER | INVALID_NUMBER
         | ELLIPSIS | LSHIFT_ASSIGN | RSHIFT_ASSIGN
         | ARROW | PLUSPLUS | MINUSMINUS | LSHIFT | RSHIFT
         | LE | GE | EQ | NE | ANDAND | OROR
         | STAR_ASSIGN | SLASH_ASSIGN | PERCENT_ASSIGN
         | PLUS_ASSIGN | MINUS_ASSIGN | AMP_ASSIGN
         | CARET_ASSIGN | PIPE_ASSIGN | HASHHASH
         | LBRACKET | RBRACKET | LPAREN | RPAREN | LBRACE | RBRACE
         | DOT | AMP | STAR | PLUS | MINUS | TILDE | BANG
         | SLASH | PERCENT | LT | GT | CARET | PIPE
         | QUESTION | COLON | SEMICOLON | ASSIGN | COMMA | HASH)*
