// C99 lexer grammar (Lark).
// Translates the hand-written grammar files:
//   docs/ints_grammar.txt, docs/floats_grammar.txt,
//   docs/chars_grammar.txt, docs/strings_grammar.txt
//
// Keyword classification is done in the wrapper (lexer.py): the KEYWORDS set
// is applied to IDENTIFIER tokens after tokenization.

// -- Integer constant (docs/ints_grammar.txt; C99 §6.4.4.1).
// Four terminals split by suffix presence — no value-driven splitting at
// lex time. The parser then maps (token-kind, base, value) to a c99_ast
// const variant per §6.4.4.1 paragraph 5 ("the type ... is the first of
// the corresponding list in which its value can be represented"). Both
// LONG_INTEGER and ULONG_INTEGER also match the `LL` form; the parser
// rejects it because c6502 has no `long long`.
_INT_L: /[lL]/
_INT_LL: /ll|LL/
_INT_U: /[uU]/
_LSUFFIX: _INT_LL | _INT_L
_HEX_INT: /0[xX][0-9a-fA-F]+/
_DECIMAL_INT: /[1-9][0-9]*/
_OCTAL_INT: /0[0-7]*/
_BARE_INT: _HEX_INT | _DECIMAL_INT | _OCTAL_INT
INTEGER_CONSTANT: _BARE_INT
LONG_INTEGER: _BARE_INT _LSUFFIX
UINT_INTEGER: _BARE_INT _INT_U
ULONG_INTEGER: _BARE_INT (_INT_U _LSUFFIX | _LSUFFIX _INT_U)

// -- Floating constant (docs/floats_grammar.txt; C99 §6.4.4.2) --
// Three terminals split by suffix presence — same shape as the four
// integer terminals (no value-driven splitting at lex time). The
// parser's `_const_for_token` then dispatches each (token-kind,
// value) pair to the matching c99_ast const variant per §6.4.4.2:
//   * unsuffixed → double (ConstDouble)
//   * f / F      → float  (ConstFloat)
//   * l / L      → long double — rejected (c6502 has no long double)
// NOTE: fractions use an explicit (?:...) group. Without it, the top-level `|`
// leaks out when these are concatenated into the enclosing terminal.
_DEC_EXP: /[eE][+-]?[0-9]+/
_BIN_EXP: /[pP][+-]?[0-9]+/
_DEC_FRAC: /(?:[0-9]*\.[0-9]+|[0-9]+\.)/
_HEX_FRAC: /(?:[0-9a-fA-F]*\.[0-9a-fA-F]+|[0-9a-fA-F]+\.?)/
_DEC_FLOAT: _DEC_FRAC _DEC_EXP? | /[0-9]+/ _DEC_EXP
_HEX_FLOAT: /0[xX]/ _HEX_FRAC _BIN_EXP
DOUBLE_CONSTANT: (_HEX_FLOAT | _DEC_FLOAT)
FLOAT_CONSTANT: (_HEX_FLOAT | _DEC_FLOAT) /[fF]/
LONG_DOUBLE_CONSTANT: (_HEX_FLOAT | _DEC_FLOAT) /[lL]/

// -- Escape sequences (docs/chars_grammar.txt) --
_SIMPLE_ESC: /\\['"?\\abfnrtv]/
_OCT_ESC: /\\[0-7]{1,3}/
_HEX_ESC: /\\x[0-9a-fA-F]+/
_U_ESC: /\\u[0-9a-fA-F]{4}/
_BIG_U_ESC: /\\U[0-9a-fA-F]{8}/
_ESCAPE: _SIMPLE_ESC | _OCT_ESC | _HEX_ESC | _U_ESC | _BIG_U_ESC

// -- Character constant (docs/chars_grammar.txt) --
// Printable ASCII minus ' (0x27) and \ (0x5C), plus the C99 §5.2.1
// "white-space characters" \t (0x09), \v (0x0B), \f (0x0C). Using
// \] (instead of \x5D) because Lark translates \x5D to a bare ],
// which would close the class early. Newlines (\x0A LF, \x0D CR)
// are NOT accepted inside character literals — that mirrors the
// C99 grammar's "any member of the source character set except the
// single-quote ', backslash \, or new-line character" rule, and
// catches missing closing quotes.
_C_CHAR: /[\x09\x0B\x0C\x20-\x26\x28-\x5B\]-\x7E]/ | _ESCAPE
CHAR_CONSTANT: /L?'/ _C_CHAR+ /'/

// -- String literal (docs/strings_grammar.txt) --
// Printable ASCII minus " (0x22) and \ (0x5C), plus \t / \v / \f.
// Newlines rejected for the same reason as _C_CHAR.
_S_CHAR: /[\x09\x0B\x0C\x20\x21\x23-\x5B\]-\x7E]/ | _ESCAPE
STRING_LITERAL: /L?"/ _S_CHAR* /"/

// -- Error-catching terminals for malformed numerics.
// Each matches a pattern that our strict grammar rejects but that a naive
// tokenizer would otherwise split into pieces (e.g. "0x" + "g"). The wrapper
// (lexer.py) raises LexError when it sees an INVALID_NUMBER.
// NOTE: *+ (possessive) prevents the regex from backtracking into a shorter
// match when the lookahead later fails — otherwise e.g. "0x.FFp0" would
// produce a spurious "0x.F" BAD match by shrinking the second digit run.
_BAD_HEX_PREFIX: /0[xX](?![0-9a-fA-F\.])/
_BAD_HEX_DOT: /0[xX]\.(?![0-9a-fA-F])/
_BAD_HEX_NO_EXP: /0[xX][0-9a-fA-F]*+\.[0-9a-fA-F]*+(?![pP])/
_BAD_HEX_EXP: /0[xX][0-9a-fA-F]*+\.?[0-9a-fA-F]*+[pP](?![+-]?[0-9])/
_BAD_DEC_EXP: /(?:[0-9]+|[0-9]*\.[0-9]+|[0-9]+\.)[eE](?![+-]?[0-9])/
INVALID_NUMBER: _BAD_HEX_PREFIX | _BAD_HEX_DOT | _BAD_HEX_NO_EXP | _BAD_HEX_EXP | _BAD_DEC_EXP

// -- Keywords (C99 §6.4.1). One terminal per keyword so parser rules can
//    refer to IF / WHILE / etc. directly. String terminals get higher
//    priority than IDENTIFIER on equal-length matches, so `int` wins over
//    IDENTIFIER for input `int` while `intx` falls through to IDENTIFIER
//    via longest match.
//    Naming: uppercase the keyword; strip leading `_` (so `_Bool` → `BOOL`).
//    Keep this list in sync with KEYWORDS in lexer.py.
AUTO: "auto"
BREAK: "break"
CASE: "case"
CHAR: "char"
CONST: "const"
CONTINUE: "continue"
DEFAULT: "default"
DO: "do"
DOUBLE: "double"
ELSE: "else"
ENUM: "enum"
EXTERN: "extern"
FLOAT: "float"
FOR: "for"
GOTO: "goto"
IF: "if"
INLINE: "inline"
INT: "int"
LONG: "long"
REGISTER: "register"
RESTRICT: "restrict"
RETURN: "return"
SHORT: "short"
SIGNED: "signed"
SIZEOF: "sizeof"
STATIC: "static"
STRUCT: "struct"
SWITCH: "switch"
TYPEDEF: "typedef"
UNION: "union"
UNSIGNED: "unsigned"
VOID: "void"
VOLATILE: "volatile"
WHILE: "while"
BOOL: "_Bool"
COMPLEX: "_Complex"
IMAGINARY: "_Imaginary"

// GCC-style attribute annotation. The only recognized form today is
// `__attribute__((<name>))`, with `<name>` being a plain IDENTIFIER.
// Used to attach an ABI annotation (e.g. `zp_abi`) to a function
// declaration; see docs/leaf_zp_abi.md.
ATTRIBUTE: "__attribute__"

// -- Identifier (placeholder alphabet, pending a grammar) --
IDENTIFIER: /[a-zA-Z_][a-zA-Z_0-9]*/

// -- Symbols (C99 punctuators). One terminal per symbol so parser rules
//    can refer to them by name (e.g. LPAREN, ARROW, PLUS_ASSIGN).
//    Keep this list in sync with SYMBOLS in lexer.py.
ELLIPSIS: "..."
LSHIFT_ASSIGN: "<<="
RSHIFT_ASSIGN: ">>="
ARROW: "->"
PLUSPLUS: "++"
MINUSMINUS: "--"
LSHIFT: "<<"
RSHIFT: ">>"
LE: "<="
GE: ">="
EQ: "=="
NE: "!="
ANDAND: "&&"
OROR: "||"
STAR_ASSIGN: "*="
SLASH_ASSIGN: "/="
PERCENT_ASSIGN: "%="
PLUS_ASSIGN: "+="
MINUS_ASSIGN: "-="
AMP_ASSIGN: "&="
CARET_ASSIGN: "^="
PIPE_ASSIGN: "|="
HASHHASH: "##"
LBRACKET: "["
RBRACKET: "]"
LPAREN: "("
RPAREN: ")"
LBRACE: "{"
RBRACE: "}"
DOT: "."
AMP: "&"
STAR: "*"
PLUS: "+"
MINUS: "-"
TILDE: "~"
BANG: "!"
SLASH: "/"
PERCENT: "%"
LT: "<"
GT: ">"
CARET: "^"
PIPE: "|"
QUESTION: "?"
COLON: ":"
SEMICOLON: ";"
ASSIGN: "="
COMMA: ","
HASH: "#"

// -- Whitespace (ignored) --

WS: /[ \t\n\f]+/
%ignore WS

// Top-level: a translation unit is a list of function declarations.

start: declaration*

// declaration (§6.7) and function-definition (§6.9.1). Both start
// with `specifier+ declarator`; the trailing form distinguishes:
//   `(ASSIGN exp)? SEMICOLON`  → var_decl
//      (a function-typed declarator with no body lands here too —
//       e.g. `int foo(int);` is a forward declaration of a function;
//       the var_decl transformer dispatches on the declarator's
//       composed type and rewraps as a FunctionDecl with body=None.)
//   `block`                    → function_decl (definition)
// LALR(1) lookahead-1 distinguishes the two on `LBRACE` vs `ASSIGN`/
// `SEMICOLON` once the declarator has been parsed.
declaration: function_decl | var_decl
specifier: type_specifier | STATIC | EXTERN
// Optional GCC-style attribute prefix on a declaration (function or
// var). Today the only legal annotation name is `zp_abi`; the
// transformer rejects any other name. Attribute appears BEFORE the
// declaration specifiers; placing it after the declarator (also
// legal in GCC) is not supported.
attribute_clause: ATTRIBUTE LPAREN LPAREN IDENTIFIER RPAREN RPAREN
// var_decl covers four shapes:
//   `int x;` / `int x = 1;`           — object declaration with declarator
//   `int foo(int);`                   — function forward decl (the var_decl
//                                       transformer rewraps as FunctionDecl
//                                       when the composed type is FunType)
//   `struct foo { int a; };`          — struct/union definition (no
//                                       declarator); becomes a StructDecl
//   `struct foo;`                     — struct/union forward declaration
// The struct/union-only forms (no declarator) take the
// `tag_only_decl` alternative.
var_decl: attribute_clause? specifier+ declarator (ASSIGN initializer)? SEMICOLON
        | attribute_clause? specifier+ SEMICOLON                -> tag_only_decl

// Initializer per C99 §6.7.8: either a single assignment-level
// expression, or a brace-enclosed list of initializers. The list
// allows a trailing comma per the standard. Items are themselves
// `initializer` for nesting (multi-dim init); the current type
// checker only validates flat single-dim init, but the recursive
// grammar leaves room without a future grammar bump.
initializer: assignment_exp                                      -> init_exp
           | LBRACE initializer (COMMA initializer)* COMMA? RBRACE -> init_list
function_decl: attribute_clause? specifier+ declarator block

type_specifier: INT | LONG | SIGNED | UNSIGNED | FLOAT | DOUBLE | CHAR | VOID
              | struct_or_union_specifier

// Struct or union specifier (C99 §6.7.2.1). Two shapes:
//   * defining: `struct tag { member_decl+ }`
//   * referring: `struct tag` (used in object declarations and
//                 forward `struct foo;` declarations alike)
// c6502 requires a tag (anonymous structs not modeled). Member-decl
// list is non-empty when present — empty bodies (`struct foo {}`)
// would be illegal per §6.7.2.1.7.
struct_or_union_specifier: STRUCT IDENTIFIER (LBRACE struct_declaration+ RBRACE)?  -> struct_specifier
                         | UNION  IDENTIFIER (LBRACE struct_declaration+ RBRACE)?  -> union_specifier

// Struct member declaration (C99 §6.7.2.1.2). Reuses `declarator`
// from §6.7.5 so members can be pointers, arrays, struct-typed,
// pointer-to-struct, etc. No bitfields. No anonymous nested
// definitions (the embedded `struct_or_union_specifier` may only
// be a tag-reference shape; the type checker enforces this).
struct_declaration: specifier_qualifier_list struct_declarator_list SEMICOLON
specifier_qualifier_list: (type_specifier | type_qualifier)+
struct_declarator_list: declarator (COMMA declarator)*

block: LBRACE block_item* RBRACE
block_item: statement    -> stmt_item
          | declaration  -> decl_item

// for-init permits a variable declaration or an expression-or-empty,
// per C99 §6.8.5: function declarations aren't legal here.

for_init: var_decl | exp? SEMICOLON

// `if (exp) statement (else statement)?` — the optional else is the
// classic dangling-else ambiguity. Lark's LALR(1) backend resolves
// shift-reduce conflicts in favor of shifting, which binds `else` to
// the nearest preceding unmatched `if` (the C99-correct rule). Lark
// emits a warning for the conflict; the warning is the expected
// behavior, not a bug.
// Labeled statements (`label: stmt`) and `goto label;` per C99 §6.8.1
// and §6.8.6. Labels live in their own namespace and are scoped to the
// enclosing function — both rules are enforced by the
// label_resolution pass, not the grammar.
//
// The labeled-statement rule introduces a shift-reduce conflict at
// statement-start: after seeing `IDENTIFIER`, lookahead `COLON` could
// either start a labeled_stmt (shift) or finish reducing the
// IDENTIFIER to a primary expression (reduce, via the
// expression_stmt path). Lark's LALR(1) backend prefers shift, which
// picks the labeled_stmt branch — exactly what we want. Inside an
// expression (e.g. ternary) the parser state is different (kernel
// items don't include the labeled_stmt option), so `a ? b : c`
// continues to parse as a ternary even though `b` is also an
// IDENTIFIER followed by COLON.

statement: RETURN exp? SEMICOLON                                    -> return_stmt
         | exp SEMICOLON                                            -> expression_stmt
         | IF LPAREN exp RPAREN statement (ELSE statement)?         -> if_stmt
         | GOTO IDENTIFIER SEMICOLON                                -> goto_stmt
         | IDENTIFIER COLON statement                               -> labeled_stmt
         | block                                                    -> compound_stmt
         | BREAK SEMICOLON                                          -> break_stmt
         | CONTINUE SEMICOLON                                       -> continue_stmt
         | WHILE LPAREN exp RPAREN statement                        -> while_stmt
         | DO statement WHILE LPAREN exp RPAREN SEMICOLON           -> do_stmt
         | FOR LPAREN for_init exp? SEMICOLON exp? RPAREN statement -> for_stmt
         | SWITCH LPAREN exp RPAREN statement                       -> switch_stmt
         | CASE constant_exp COLON statement                        -> case_stmt
         | DEFAULT COLON statement                                  -> default_stmt
         | SEMICOLON                                                -> null_stmt

// C99 §6.6: a constant-expression is syntactically just a
// conditional-expression but is constrained semantically per §6.6
// paragraphs 3–6 (no assignment / inc / dec / function-call / comma
// operators; integer-constant-expression sites also require integer
// type and integer operands per §6.6.6). The non-terminal exists so
// call sites that require a constant expression are self-documenting
// and share a single validator (see passes/constant_expression.py).
// The transformer just unwraps the single child — the §6.6 check is
// purely semantic.
constant_exp: conditional_exp

// Expression precedence (low to high) via the standard precedence-
// climbing layout: each level recurses left into itself (for left
// associativity) and right into the next-tighter level. Lark's `?`
// rule prefix inlines a level when it has a single child, so the
// AST sees no extra wrapping for "passes through to next level".

?exp: assignment_exp

// Right-recursive so `=` is right-associative: `a = b = c` parses as
// `a = (b = c)`. The LHS is `conditional_exp` (one level tighter than
// assignment, same as C99's §6.5.16 but looser than C99's `unary_exp`),
// which means the grammar accepts things like `1+2=3+4` and
// `(1?2:a)=5` — semantic analysis will reject the first by checking
// for modifiable lvalues. The compound-assignment alternatives share
// the `compound_assign` builder, which dispatches on the operator
// token's type and emits the desugared `lval = lval OP rval`.

?assignment_exp: conditional_exp ASSIGN assignment_exp         -> assignment
               | conditional_exp PLUS_ASSIGN assignment_exp    -> compound_assign
               | conditional_exp MINUS_ASSIGN assignment_exp   -> compound_assign
               | conditional_exp STAR_ASSIGN assignment_exp    -> compound_assign
               | conditional_exp SLASH_ASSIGN assignment_exp   -> compound_assign
               | conditional_exp PERCENT_ASSIGN assignment_exp -> compound_assign
               | conditional_exp AMP_ASSIGN assignment_exp     -> compound_assign
               | conditional_exp PIPE_ASSIGN assignment_exp    -> compound_assign
               | conditional_exp CARET_ASSIGN assignment_exp   -> compound_assign
               | conditional_exp LSHIFT_ASSIGN assignment_exp  -> compound_assign
               | conditional_exp RSHIFT_ASSIGN assignment_exp  -> compound_assign
               | conditional_exp

// Ternary `cond ? then : else`. The condition is `logical_or_exp`, so
// `||` binds tighter than `?:`. The true-clause is a full `exp` (so
// `x ? x = 1 : 2` parses as `x ? (x = 1) : 2`). The false-clause is
// `conditional_exp`, which gives `?:` right-associativity (`a ? 1 : b ?
// 2 : 3` parses as `a ? 1 : (b ? 2 : 3)`) and keeps assignments out of
// the false-clause slot — so `1 ? 2 : a = 5` parses as `(1 ? 2 : a) = 5`
// via the outer assignment rule, not `1 ? 2 : (a = 5)`.

?conditional_exp: logical_or_exp QUESTION exp COLON conditional_exp -> conditional
                | logical_or_exp
?logical_or_exp: logical_or_exp OROR logical_and_exp  -> logical_or
               | logical_and_exp
?logical_and_exp: logical_and_exp ANDAND or_exp       -> logical_and
                | or_exp
?or_exp: or_exp PIPE xor_exp        -> bitwise_or
       | xor_exp
?xor_exp: xor_exp CARET and_exp     -> bitwise_xor
        | and_exp
?and_exp: and_exp AMP equality_exp  -> bitwise_and
        | equality_exp
?equality_exp: equality_exp EQ relational_exp  -> equal
             | equality_exp NE relational_exp  -> not_equal
             | relational_exp
?relational_exp: relational_exp LT shift_exp   -> less_than
               | relational_exp GT shift_exp   -> greater_than
               | relational_exp LE shift_exp   -> less_or_equal
               | relational_exp GE shift_exp   -> greater_or_equal
               | shift_exp
?shift_exp: shift_exp LSHIFT add_exp -> left_shift
          | shift_exp RSHIFT add_exp -> right_shift
          | add_exp
?add_exp: add_exp PLUS mul_exp      -> add
        | add_exp MINUS mul_exp     -> subtract
        | mul_exp
?mul_exp: mul_exp STAR cast_exp     -> multiply
        | mul_exp SLASH cast_exp    -> divide
        | mul_exp PERCENT cast_exp  -> modulo
        | cast_exp

// Cast expression (C99 §6.5.4) sits between unary and multiplicative.
// Right-recursive so `(int)(long)x` parses as `(int)((long)x)`. The
// LPAREN-vs-paren-expr ambiguity is resolved at LALR(1) by the next
// token after `(`: any type-specifier token (INT/LONG/SIGNED/
// UNSIGNED/FLOAT/DOUBLE) → cast; anything else → parenthesised exp.

?cast_exp: LPAREN type_name RPAREN cast_exp  -> cast
         | unary_exp

// Prefix `++`/`--` sit at unary precedence (alongside `-`/`~`/`!`) and
// desugar at parse time to `lval = lval ± 1` — same shape as a compound
// assignment, so no AST node is needed. Postfix `a++`/`a--` need their
// own node because they evaluate to the *old* value of the operand
// while still mutating it; that can't be expressed by reusing
// Assignment/Binary alone. The unary-operator alternative takes a
// `cast_exp` (per §6.5.3.1) so `-(int)x` parses as `-((int)x)`;
// prefix ++/-- keep their unary_exp operand because the cast result
// isn't an lvalue.
//
// Indirection `*e` and address-of `&e` (C99 §6.5.3.2) sit at unary
// precedence and take a `cast_exp` operand (per §6.5.3.1), same as
// the other unary operators. They build their own AST nodes
// (`Dereference` / `AddressOf`) rather than going through `unop` /
// `unary` because the AST models them as standalone exp variants,
// not as variants of `unary_operator` (the type checker tracks
// `Pointer`-ness through them, which the Complement/Negate/LogicalNot
// trio doesn't need). The STAR-vs-multiply and AMP-vs-bitwise-AND
// ambiguity is resolved the same way unary minus already is: at the
// LALR(1) state level — these productions only fire when the parser
// is starting a fresh unary_exp, while the binary forms only fire
// after a left operand has already reduced.

?unary_exp: unop cast_exp            -> unary
          | STAR cast_exp            -> dereference
          | AMP cast_exp             -> address_of
          | PLUSPLUS unary_exp       -> pre_increment
          | MINUSMINUS unary_exp     -> pre_decrement
          | SIZEOF LPAREN type_name RPAREN -> sizeof_type
          | SIZEOF unary_exp         -> sizeof_exp
          | postfix_exp
?postfix_exp: postfix_exp PLUSPLUS   -> post_increment
            | postfix_exp MINUSMINUS -> post_decrement
            | postfix_exp LBRACKET exp RBRACKET -> subscript
            | postfix_exp DOT IDENTIFIER        -> member_dot
            | postfix_exp ARROW IDENTIFIER      -> member_arrow
            | atom

// Function call sits at atom level (one form of primary expression
// per C99 §6.5.2). The IDENTIFIER LPAREN form is shift/reduce-
// distinguishable from the bare-identifier form on LPAREN lookahead:
// after IDENTIFIER, LALR(1) sees LPAREN and shifts (function_call);
// any other lookahead reduces to identifier→atom. The AST node
// FunctionCall(name, args) takes the callee as a string identifier
// (not a general expression). The two grammar alternatives supply
// the name from different shapes:
//   `IDENTIFIER LPAREN args RPAREN`  → bare-name callee `foo(args)`.
//   `LPAREN exp RPAREN LPAREN args RPAREN` → parenthesised-callee
//     forms like `(*fp)(args)` or `(fp)(args)`. The transformer
//     accepts only the shapes that boil down to a single named
//     identifier (Var / Dereference-of-Var / AddressOf-of-Var)
//     since the AST node only carries a string name; richer
//     callee expressions would need a different AST shape.
//
// LALR(1) note: the `LPAREN exp RPAREN` form shares its prefix
// with the plain `paren` atom, creating a shift-reduce on the
// trailing-LPAREN lookahead. Lark's shift-preference picks the
// indirect_function_call alternative when another LPAREN follows,
// which is what we want — anything else reduces to paren.

?atom: const                       -> constant
     | LPAREN exp RPAREN                      -> paren
     | STRING_LITERAL+                        -> str_literal
     | LPAREN exp RPAREN LPAREN arg_list? RPAREN -> indirect_function_call
     | IDENTIFIER LPAREN arg_list? RPAREN     -> function_call
     | IDENTIFIER                             -> identifier
const: INTEGER_CONSTANT
     | LONG_INTEGER
     | UINT_INTEGER
     | ULONG_INTEGER
     | DOUBLE_CONSTANT
     | FLOAT_CONSTANT
     | LONG_DOUBLE_CONSTANT
     | CHAR_CONSTANT

unop: MINUS                         -> negate
    | TILDE                         -> complement
    | BANG                          -> logical_not

// Argument-list nodes: each arg is a full `exp` (assignment-level
// expression — comma operator isn't supported, so this matches C's
// argument-expression-list grammar).

arg_list: exp (COMMA exp)*

// Type qualifiers (§6.7.3) — accepted by the grammar so qualified
// types parse without fuss in pointers / arrays / parameter lists /
// casts. None of them are modelled in the AST today (no const-
// correctness, no `restrict` aliasing analysis, no `volatile`
// memory-fence emission), so the transformer treats them as syntax-
// only noise.
type_qualifier: CONST | RESTRICT | VOLATILE

// Declarators (§6.7.5).
//
// A declarator names something and gives the derived (pointer /
// array / function) type that wraps the declaration's specifier-
// supplied base type. This rule set is grammatically complete but
// is not yet wired into `var_decl` / `function_decl` above (those
// still accept only the bare-IDENTIFIER form). When they migrate,
// pointer locals (`int *p;`), array locals (`int a[10];`), and
// function-pointer locals follow.
declarator: pointer? direct_declarator
pointer: STAR type_qualifier* pointer?

// `direct-declarator` is left-recursive across array (`[...]`) and
// function (`(...)`) suffixes — `int *a[3]()` parses as
// `*(a[3]())` (an array-of-functions; rejected at type-check time
// but syntactically valid). The two function alternatives cover
// prototype-form `(parameter-type-list)` and old-style K&R
// `(identifier-list_opt)`.
direct_declarator: IDENTIFIER
                 | LPAREN declarator RPAREN
                 | direct_declarator LBRACKET array_suffix RBRACKET
                 | direct_declarator LPAREN parameter_type_list RPAREN
                 | direct_declarator LPAREN VOID RPAREN
                 | direct_declarator LPAREN identifier_list? RPAREN

// Array-suffix variants per §6.7.5.2:
//   [ type-qualifier-list_opt assignment-expression_opt ]
//   [ static type-qualifier-list_opt assignment-expression ]
//   [ type-qualifier-list static assignment-expression ]
//   [ type-qualifier-list_opt * ]   (VLA "of unspecified size")
// The `static` form (§6.7.5.2.2) declares a minimum-size assertion;
// the `*` form (§6.7.5.2.1) is valid only in function-prototype
// scope. Listed STATIC-first / qualifier-then-STATIC / STAR /
// fallback so each lookahead picks one alternative deterministically.
array_suffix: STATIC type_qualifier* assignment_exp     -> array_size_static
            | type_qualifier+ STATIC assignment_exp     -> array_size_quals_static
            | type_qualifier* STAR                      -> array_size_unspec
            | type_qualifier* assignment_exp?           -> array_size_plain

// Parameter type list (§6.7.5.3). The trailing `, ...` covers
// variadic functions; c6502 has no variadic AST node yet so the
// transformer rejects it, but the grammar accepts it.
//
// LALR(1) note: writing this as
// `parameter_list (COMMA ELLIPSIS)?` would create a shift-reduce
// at the trailing COMMA — at the kernel item `parameter_list .`
// with lookahead COMMA, the parser can't tell whether the COMMA
// extends `parameter_list` (with another `parameter_declaration`)
// or starts the optional `, ...` suffix. Lark's shift-preference
// resolves it toward the extension, breaking variadic parses. We
// dodge by treating ELLIPSIS as a pseudo-parameter inside the
// repetition: the COMMA decision is made *before* the next item,
// then the `parameter_or_ellipsis` alternative cleanly picks
// parameter_declaration vs. ELLIPSIS by FIRST set. The AST builder
// (when wired through) is responsible for enforcing C99's
// "ELLIPSIS only at the end" constraint.
parameter_type_list: parameter_declaration (COMMA parameter_or_ellipsis)*
parameter_or_ellipsis: parameter_declaration | ELLIPSIS

// Per §6.7.5: a parameter declaration is `declaration-specifiers`
// followed by either a (named) `declarator` or an (unnamed,
// optional) `abstract-declarator`. The two alternatives share the
// FIRST set of `LPAREN` / `STAR` / `LBRACKET` after the specifiers,
// so LALR(1) sees a shift-reduce ambiguity here. Lark resolves it
// via shift-preference, which biases toward the `declarator`
// alternative — fine for now, since the transformer only needs the
// grammar to accept both shapes; the AST builder for parameters
// (when wired through) will inspect the resulting tree to pick
// which alternative was actually meant.
parameter_declaration: specifier+ declarator
                     | specifier+ abstract_declarator?

// Old-style K&R identifier list (§6.7.5). Accepted for grammar
// completeness; the c6502 AST has no representation for K&R-style
// declarators, so the transformer rejects them when encountered.
identifier_list: IDENTIFIER (COMMA IDENTIFIER)*

// Abstract declarators (§6.7.6) — declarators with the identifier
// omitted, used in type-names (cast targets) and unnamed parameter
// declarations. Covers three shapes:
//   pointer alone:                          int *
//   pointer + direct_abstract:              int *(*)(int)
//   direct_abstract alone:                  int (*)(int), int [3]
abstract_declarator: pointer
                   | pointer? direct_abstract_declarator

// Same array / function suffixes as `direct_declarator`, but with
// the recursive prefix optional. C99 writes that as
// `direct-abstract-declarator_opt [...]` etc.; LALR(1) needs the
// `_opt` expanded into separate "with prefix" / "without prefix"
// alternatives so the parser doesn't have to look past the
// LBRACKET / LPAREN to decide whether a prefix is coming. The
// `LPAREN abstract_declarator RPAREN` / `LPAREN parameter_type_list?
// RPAREN` ambiguity at the start of an empty-prefix form is
// resolved by lookahead-1: STAR / LPAREN / LBRACKET after the outer
// LPAREN start an abstract_declarator (parenthesised), while a
// type-specifier or RPAREN starts the function form.
direct_abstract_declarator: LPAREN abstract_declarator RPAREN
                          | direct_abstract_declarator LBRACKET array_suffix RBRACKET
                          | direct_abstract_declarator LPAREN parameter_type_list? RPAREN
                          | direct_abstract_declarator LPAREN VOID RPAREN
                          | LBRACKET array_suffix RBRACKET
                          | LPAREN parameter_type_list? RPAREN
                          | LPAREN VOID RPAREN

// type-name (§6.7.6). Used inside cast expressions. Without an
// abstract_declarator the transformer maps the run of type_specifier
// tokens to a c99_ast Int / Long / UInt / ULong / Float / Double via
// `_resolve_data_type` — same behavior as before. With an
// abstract_declarator present (e.g., `(int *)x`), the transformer
// composes a Pointer wrapping above the base type for pure-pointer
// abstract declarators and rejects the array / function-pointer
// shapes (no AST plumbing for them yet).

type_name: type_specifier+ abstract_declarator?

// Lexer-only start rule. Lark's LALR mode drops terminals that aren't
// reachable from a start rule, which would shrink the lexer as long as
// the parser rules above don't cover everything. Passing this as an
// additional start in lexer.py keeps every terminal alive for .lex().
// Remove when the real parser rules cover the full language.

lex_only: (AUTO | BREAK | CASE | CHAR | CONST | CONTINUE
         | DEFAULT | DO | DOUBLE | ELSE | ENUM | EXTERN
         | FLOAT | FOR | GOTO | IF | INLINE | INT | LONG
         | REGISTER | RESTRICT | RETURN | SHORT | SIGNED
         | SIZEOF | STATIC | STRUCT | SWITCH | TYPEDEF | UNION
         | UNSIGNED | VOID | VOLATILE | WHILE
         | BOOL | COMPLEX | IMAGINARY | ATTRIBUTE
         | INTEGER_CONSTANT | LONG_INTEGER | UINT_INTEGER | ULONG_INTEGER
         | DOUBLE_CONSTANT | FLOAT_CONSTANT | LONG_DOUBLE_CONSTANT
         | CHAR_CONSTANT
         | STRING_LITERAL | IDENTIFIER | INVALID_NUMBER
         | ELLIPSIS | LSHIFT_ASSIGN | RSHIFT_ASSIGN
         | ARROW | PLUSPLUS | MINUSMINUS | LSHIFT | RSHIFT
         | LE | GE | EQ | NE | ANDAND | OROR
         | STAR_ASSIGN | SLASH_ASSIGN | PERCENT_ASSIGN
         | PLUS_ASSIGN | MINUS_ASSIGN | AMP_ASSIGN
         | CARET_ASSIGN | PIPE_ASSIGN | HASHHASH
         | LBRACKET | RBRACKET | LPAREN | RPAREN | LBRACE | RBRACE
         | DOT | AMP | STAR | PLUS | MINUS | TILDE | BANG
         | SLASH | PERCENT | LT | GT | CARET | PIPE
         | QUESTION | COLON | SEMICOLON | ASSIGN | COMMA | HASH)*
